PORT=3000
JWT_SECRET=platzhalter_fuer_jwt_passwort
DB_LOGGING=false

# Client Basis-URL fuer Einladungslinks
APP_BASE_URL=http://localhost:5173

# Mail-Modus: auto | smtp | ethereal | console
# auto: smtp wenn konfiguriert, sonst ethereal, sonst console
MAIL_MODE=auto

# SMTP (nur fuer MAIL_MODE=smtp oder auto mit SMTP-Config)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@feels-like.local